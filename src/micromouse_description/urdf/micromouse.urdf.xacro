<?xml version="1.0"?>
<robot name="micromouse" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="controllers_yaml" default=""/>

  <!-- ===================== dimensions ===================== -->
  <xacro:property name="base_size" value="0.07"/>
  <xacro:property name="base_height" value="0.025"/>
  <xacro:property name="base_z" value="0.02"/>
  <xacro:property name="base_mass" value="0.12"/>

  <xacro:property name="wheel_radius" value="0.016"/>
  <xacro:property name="wheel_width" value="0.008"/>
  <xacro:property name="wheel_separation" value="0.08"/>
  <xacro:property name="wheel_mass" value="0.02"/>

  <xacro:property name="caster_radius" value="0.008"/>
  <xacro:property name="caster_mass" value="0.005"/>
  <xacro:property name="caster_z" value="${-(wheel_radius - caster_radius)}"/>

  <xacro:property name="ir_range_min" value="0.01"/>
  <xacro:property name="ir_range_max" value="0.5"/>
  <xacro:property name="ir_noise_stddev" value="0.005"/>
  <xacro:property name="ir_update_rate" value="20"/>

  <material name="chassis_white"><color rgba="0.92 0.92 0.9 1"/></material>
  <material name="wheel_black"><color rgba="0.1 0.1 0.1 1"/></material>
  <material name="ir_dark"><color rgba="0.05 0.05 0.05 1"/></material>

  <!-- ===================== base ===================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_z}" rpy="0 0 0"/>
      <geometry><box size="${base_size} ${base_size} ${base_height}"/></geometry>
      <material name="chassis_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_z}" rpy="0 0 0"/>
      <geometry><box size="${base_size} ${base_size} ${base_height}"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${base_z}" rpy="0 0 0"/>
      <mass value="${base_mass}"/>
      <inertia
        ixx="${base_mass*(base_size*base_size+base_height*base_height)/12}" ixy="0" ixz="0"
        iyy="${base_mass*(base_size*base_size+base_height*base_height)/12}" iyz="0"
        izz="${base_mass*(base_size*base_size+base_size*base_size)/12}"/>
    </inertial>
  </link>

  <!-- ===================== wheels ===================== -->
  <xacro:macro name="wheel" params="prefix reflect">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia
          ixx="${wheel_mass*(3*wheel_radius*wheel_radius+wheel_width*wheel_width)/12}" ixy="0" ixz="0"
          iyy="${0.5*wheel_mass*wheel_radius*wheel_radius}" iyz="0"
          izz="${wheel_mass*(3*wheel_radius*wheel_radius+wheel_width*wheel_width)/12}"/>
      </inertial>
    </link>
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="0 ${reflect*wheel_separation/2} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
    <gazebo reference="${prefix}_wheel_link">
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
    </gazebo>
  </xacro:macro>

  <xacro:wheel prefix="left" reflect="1"/>
  <xacro:wheel prefix="right" reflect="-1"/>

  <!-- ===================== casters (unpowered support points) ===================== -->
  <xacro:macro name="caster" params="prefix x">
    <link name="${prefix}_caster_link">
      <visual>
        <geometry><sphere radius="${caster_radius}"/></geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <geometry><sphere radius="${caster_radius}"/></geometry>
      </collision>
      <inertial>
        <mass value="${caster_mass}"/>
        <inertia
          ixx="${0.4*caster_mass*caster_radius*caster_radius}" ixy="0" ixz="0"
          iyy="${0.4*caster_mass*caster_radius*caster_radius}" iyz="0"
          izz="${0.4*caster_mass*caster_radius*caster_radius}"/>
      </inertial>
    </link>
    <joint name="${prefix}_caster_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${prefix}_caster_link"/>
      <origin xyz="${x} 0 ${caster_z}" rpy="0 0 0"/>
    </joint>
    <gazebo reference="${prefix}_caster_link">
      <mu1>0.01</mu1>
      <mu2>0.01</mu2>
    </gazebo>
  </xacro:macro>

  <xacro:caster prefix="front" x="${base_size/2 - 0.005}"/>
  <xacro:caster prefix="back" x="${-(base_size/2 - 0.005)}"/>

  <!-- ===================== IR range sensors ===================== -->
  <xacro:macro name="ir_sensor" params="name x y yaw">
    <link name="${name}_link">
      <visual>
        <geometry><box size="0.006 0.006 0.006"/></geometry>
        <material name="ir_dark"/>
      </visual>
      <inertial>
        <mass value="0.001"/>
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}_link"/>
      <origin xyz="${x} ${y} ${base_z}" rpy="0 0 ${yaw}"/>
    </joint>
    <gazebo reference="${name}_link">
      <sensor name="${name}" type="gpu_lidar">
        <pose>0 0 0 0 0 0</pose>
        <topic>${name}</topic>
        <update_rate>${ir_update_rate}</update_rate>
        <always_on>true</always_on>
        <visualize>false</visualize>
        <lidar>
          <scan>
            <horizontal>
              <samples>1</samples>
              <min_angle>0.0</min_angle>
              <max_angle>0.0</max_angle>
            </horizontal>
            <vertical>
              <samples>1</samples>
              <min_angle>0.0</min_angle>
              <max_angle>0.0</max_angle>
            </vertical>
          </scan>
          <range>
            <min>${ir_range_min}</min>
            <max>${ir_range_max}</max>
            <resolution>0.001</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>${ir_noise_stddev}</stddev>
          </noise>
        </lidar>
      </sensor>
    </gazebo>
  </xacro:macro>

  <xacro:ir_sensor name="ir_front" x="${base_size/2 + 0.005}" y="0" yaw="0"/>
  <xacro:ir_sensor name="ir_left" x="0" y="${base_size/2 + 0.005}" yaw="1.5708"/>
  <xacro:ir_sensor name="ir_right" x="0" y="${-(base_size/2 + 0.005)}" yaw="-1.5708"/>

  <!-- ===================== IMU (heading reference) =====================
       Wheel-encoder yaw drifts with slip; a body-frame IMU gives a
       drift-free orientation reference (standard micromouse gyro role).
       Mounted at the chassis center, axes aligned with base_link. -->
  <link name="imu_link">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 ${base_z}" rpy="0 0 0"/>
  </joint>
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <topic>imu</topic>
      <update_rate>100</update_rate>
      <always_on>true</always_on>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- ===================== ros2_control ===================== -->
  <ros2_control name="micromouse_hardware" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(arg controllers_yaml)</parameters>
    </plugin>
  </gazebo>

</robot>

